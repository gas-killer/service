.DS_Store
/target
.env
config/config.json
config/.nodes/
!config/.nodes/.gitkeep
!config/.nodes/operator_keys/
!config/.nodes/operator_keys/.gitkeep

# Test artifacts
/logs
test_processes.pids
*.log
*.bak

# Script build artifacts
scripts/target

# Helm chart dependencies (fetch via `helm dependency update`)
helm/gas-killer/charts/*.tgz

# Terraform state (should use remote backend)
terraform.tfstate
terraform.tfstate.*
*.tfstate
*.tfstate.*

# Router SQLite store — created at runtime under DATA_DIR; never committed.
# Matches the database file and its WAL/SHM sidecars in any directory.
router.db
router.db-*
/data/