# =============================================================================
# AVS Router Configuration
# =============================================================================

# This configuraiton file is used by the E2E test CI/CD workflows

# =============================================================================
# Rust Configuration
# =============================================================================
RUST_LOG=info

# =============================================================================
# Network Configuration (Sepolia - Primary Chain)
# =============================================================================
# For TESTNET mode (Sepolia)
# HTTP_RPC=https://ethereum-sepolia-rpc.publicnode.com # Change to private rpc
# WS_RPC=wss://ethereum-sepolia-rpc.publicnode.com # Change to private websocket

# For LOCAL mode
HTTP_RPC=http://localhost:8545
WS_RPC=ws://localhost:8545
FORK_URL=https://ethereum-sepolia-rpc.publicnode.com

# =============================================================================
# Network Configuration (L2 - Optional)
# =============================================================================
# Uncomment to enable L2 chain support
# For TESTNET mode (L2)
# L2_HTTP_RPC=https://rpc.gnosischain.com
# L2_WS_RPC=wss://rpc.gnosischain.com/wss

# =============================================================================
# Router Configuration
# =============================================================================
# Quorum number to use (default: 0)
# QUORUM_NUMBER=0

# Max seconds the executor waits for a verifyAndUpdate transaction receipt before
# timing out the round and proceeding to the next one. Prevents an indefinite
# stall under L1 mempool congestion or RPC degradation. Applies to all chains;
# leave unset to use the per-chain defaults (L1: 120s, L2: 30s).
# EXECUTOR_RECEIPT_TIMEOUT_SECS=120

# Max seconds the router waits for operator signatures on a round before abandoning
# it and moving to the next queued task (accepts fractional seconds; default: 30).
# The orchestrator aggregates and submits immediately once the signature threshold
# is reached, so this is a recovery window for stalled rounds, not a throttle.
# Tradeoff: it must comfortably exceed worst-case node compute + sign time or rounds
# time out before operators finish, but every stalled round (operators offline,
# threshold unreachable) blocks the queue for the full window. Tune against the
# gas_killer_p2p_round_trip_seconds and round-timeout metrics.
# AGGREGATION_TIMEOUT=300

# =============================================================================
# P2P Channel Configuration
# =============================================================================
# P2P_MESSAGE_BACKLOG: depth of the per-channel message queue (default: 256).
# Once full, incoming messages are dropped. Increase if operators or the router
# fall behind under bursts; the cost is memory proportional to message size.
# P2P_MESSAGE_BACKLOG=256
#
# P2P_MESSAGES_PER_SECOND: rate limit for the P2P channel (default: 1.0).
# Accepts floats — use values < 1.0 for sub-second intervals (e.g. 0.5 = one
# message every two seconds) or > 1.0 for higher throughput. This is a smooth
# rate with no burst allowance: 5.0 means one message every 200ms, not bursts
# of five. Raising this beyond what gas-analyzer can process will cause queue
# buildup on the node.
# P2P_MESSAGES_PER_SECOND=1.0

# =============================================================================
# AVS Service Manager Wrapper Configuration
# =============================================================================
# These values are passed as immutable constructor parameters when deploying
# AvsServiceManagerWrapper and CANNOT be changed after deployment.
#
# QUORUM_THRESHOLD / THRESHOLD_DENOMINATOR: fraction of total registered
# operator stake that must sign a task for it to be accepted. 2/3 means at
# least two-thirds of stake-weighted operators must co-sign.
#
# BLOCK_STALE_MEASURE: maximum age (in blocks) of a valid reference block.
# At ~12 s/block on Ethereum, 300 blocks ≈ 1 hour. The service also reuses this as an
# off-chain policy bound: ingress rejects requests whose block_height is older than this,
# and the speculative executor cache is sized to cover this window.
QUORUM_THRESHOLD=2
THRESHOLD_DENOMINATOR=3
BLOCK_STALE_MEASURE=300

# Speculative executor pre-build: the node/router watch each chain's head and pre-build the
# EVMSketch executor for the latest block so a task's first validation hits the cache instead
# of paying the ~80-120 ms build() on the critical path. The cached executor only feeds the
# (discarded) gas estimate, never the signed storage_updates, so building at the tip is safe.
# SPECULATIVE_PREBUILD: set to false/0/no to disable the loop (default: true)
# SPECULATIVE_PREBUILD_POLL_MS: head-poll interval in milliseconds (default: 2000)
# SPECULATIVE_PREBUILD_CONFIRMATIONS: blocks behind head to target (default: 0 = tip)
SPECULATIVE_PREBUILD=true
SPECULATIVE_PREBUILD_POLL_MS=2000
SPECULATIVE_PREBUILD_CONFIRMATIONS=0

# =============================================================================
# Environment Mode
# =============================================================================
ENVIRONMENT=LOCAL
# ENVIRONMENT=TESTNET

