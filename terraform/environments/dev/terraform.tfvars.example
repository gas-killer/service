# =============================================================================
# Gas Killer Router - Terraform Configuration
# =============================================================================
#
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# IMPORTANT: Never commit terraform.tfvars with real secrets to git!
# =============================================================================

# AWS Configuration
aws_region = "us-east-1"

# EKS Configuration (cost-optimized for dev)
kubernetes_version  = "1.29"
node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 3

# Gas Killer Configuration
environment_mode = "LOCAL" # Use "TESTNET" for direct Sepolia connection
node_count       = 3

# =============================================================================
# SECRETS - Fill these in with your actual values
# =============================================================================

# RPC URL for Anvil to fork from (required for LOCAL mode)
# Example: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
fork_url = ""

# RPC URL for direct Sepolia connection (required for TESTNET mode)
# Example: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
rpc_url = ""

# Deployer private key (without 0x prefix)
# This key will be used to deploy contracts
# For testing, you can use an Anvil default key
private_key = ""

# Funded account private key (without 0x prefix)
# LOCAL mode: Anvil will auto-fund this account
# TESTNET mode: This account needs real Sepolia ETH for gas
funded_key = ""

# =============================================================================
# Container Images (optional - defaults to GHCR)
# =============================================================================

# Use defaults from GHCR
# node_image_repository   = "ghcr.io/breadchaincoop/gas-killer-node"
# node_image_tag          = "dev"
# router_image_repository = "ghcr.io/breadchaincoop/gas-killer-router"
# router_image_tag        = "dev"

# Or use ECR images (replace with your ECR repo)
# node_image_repository   = "123456789012.dkr.ecr.us-east-1.amazonaws.com/gas-killer-node"
# node_image_tag          = "v1.0.0"
# router_image_repository = "123456789012.dkr.ecr.us-east-1.amazonaws.com/gas-killer-router"
# router_image_tag        = "v1.0.0"

# =============================================================================
# Ingress Configuration
# =============================================================================

enable_ingress = true
# ingress_host = "gas-killer.example.com"  # Optional: custom hostname

# =============================================================================
# E2E Test Configuration
# =============================================================================

# Run E2E test after deployment (deploys ArraySummation contract and triggers Gas Killer)
run_e2e_test = true

# ArraySummation factory address on Sepolia
# array_summation_factory_address = "0xF7ded769418Ec1Db4DA3bd2d47ab72ce2296A032"
